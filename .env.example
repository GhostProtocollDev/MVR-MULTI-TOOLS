# ============================================
# GHOST Remote Access - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Database ---
# PostgreSQL connection string (use Supabase or Neon for production)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="https://your-domain.vercel.app"

# --- Google OAuth ---
# Create credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Owner System ---
# Used to initialize the first owner account on deployment
OWNER_USERNAME="your-owner-username"
OWNER_PASSWORD="your-strong-password"
OWNER_LICENSE="GHOST-XXXX-XXXX-XXXX-XXXX"
OWNER_RECOVERY_EMAIL="your-email@example.com"
OWNER_MAX_SESSIONS=5
OWNER_SESSION_DURATION_HOURS=24

# --- Stripe ---
# API keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs - Create products/prices in Stripe Dashboard
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# --- App ---
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_NAME="GHOST Remote Access"

# --- SMTP (optional) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@ghostlicenses.com"

# --- File Uploads ---
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE=5242880
